#include <stdio.h>

int main() {

    printf("The character pyramid is:\n");

    for(int i = 1; i <= 5; i++) {

        for(int sp = 5 - i; sp >= 1; sp--) {
            printf(" ");
        }

        for(int j = 1; j <= i; j++) {
            printf("%c", j + 64);
        }

        for(int j = i - 1; j >= 1; j--) {
            printf("%c", j + 64);
        }

        printf("\n");
    }

    return 0;
}
